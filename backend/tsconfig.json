{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2020",
    "module": "commonjs",

    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // "moduleResolution": "node",

    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ]
  },

  // "include": [
  //   "src/**/*"
  // ],
  "include": [
  "src/**/*",
  "src/types/**/*.d.ts"
],

  "exclude": [
    "node_modules",
    "dist"
  ]
}